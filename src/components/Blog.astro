---
import { getCollection } from 'astro:content';
import { strings } from '../i18n/strings';

const en = strings.en.blog;
const fr = strings.fr.blog;

const posts = await getCollection('blog');
posts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<section id="blog">
  <div class="container">
    <h2 class="section-heading">
      <span data-lang-en>{en.heading}</span>
      <span data-lang-fr>{fr.heading}</span>
    </h2>

    <div class="blog-grid">
      {posts.map((post) => (
        <article class="post-card" data-post-lang={post.data.lang}>
          <div class="post-meta">
            <time datetime={post.data.date}>{post.data.date}</time>
            <span class="separator">·</span>
            <span>{post.data.readTime}</span>
          </div>
          <h3 class="post-title">{post.data.title}</h3>
          <p class="post-excerpt">{post.data.excerpt}</p>
          <a href={post.data.url ?? `${import.meta.env.BASE_URL}blog/${post.id.replace(/\.mdx?$/, '')}`} class="read-more" target={post.data.url ? '_blank' : undefined} rel={post.data.url ? 'noopener noreferrer' : undefined}>
            <span data-lang-en>{en.readMore}</span>
            <span data-lang-fr>{fr.readMore}</span>
          </a>
        </article>
      ))}
    </div>
  </div>
</section>

<hr class="divider" />

<style>
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-top: 2.5rem;
  }

  .post-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
  }

  .post-meta {
    font-size: 0.75rem;
    color: var(--text-muted);
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
  }

  .separator {
    color: var(--border);
  }

  .lang-badge {
    background: var(--bg);
    border: 1px solid var(--border);
    padding: 0.1rem 0.35rem;
    border-radius: 3px;
    font-size: 0.65rem;
    color: var(--text-muted);
  }

  .post-title {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 0.6rem;
    line-height: 1.4;
  }

  .post-excerpt {
    font-size: 0.82rem;
    color: var(--text-secondary);
    line-height: 1.7;
    flex: 1;
    margin-bottom: 1.25rem;
  }

  .read-more {
    font-size: 0.82rem;
    color: var(--blue);
    align-self: flex-start;
  }

  /* Lang filtering — mirror the tokens.css pattern */
  [data-post-lang="fr"] { display: none; }
  :global(html[data-lang="fr"]) [data-post-lang="fr"] { display: flex; }
  :global(html[data-lang="fr"]) [data-post-lang="en"] { display: none; }

  @media (max-width: 900px) {
    .blog-grid { grid-template-columns: 1fr 1fr; }
  }

  @media (max-width: 600px) {
    .blog-grid { grid-template-columns: 1fr; }
  }
</style>
